#!/usr/bin/env node
/**
 * テスト用の偽Codex CLI。実際のCodex/ChatGPTには一切接続しない。
 * 環境変数で挙動を制御する:
 *   FAKE_CODEX_STATE = loggedin | loggedout          (account/read の結果)
 *   FAKE_CODEX_LOGIN = success | fail | none         (login/completed 通知)
 *   FAKE_CODEX_CRASH = 1                             (initialize直後に異常終了)
 *   FAKE_CODEX_TURN_SLEEP = ミリ秒                    (ターン完了までの遅延)
 */
const mode = process.argv[2];

if (mode === "app-server") {
  if (process.env.FAKE_CODEX_CRASH === "1") {
    // 起動直後に異常終了(再起動しても回復しないケースを再現)
    process.exit(1);
  }
  const state = process.env.FAKE_CODEX_STATE ?? "loggedin";
  const login = process.env.FAKE_CODEX_LOGIN ?? "success";
  let threadCount = 0;
  const send = (obj) => process.stdout.write(JSON.stringify(obj) + "\n");
  let buf = "";
  process.stdin.on("data", (d) => {
    buf += d.toString();
    let i;
    while ((i = buf.indexOf("\n")) >= 0) {
      const line = buf.slice(0, i).trim();
      buf = buf.slice(i + 1);
      if (!line) continue;
      const msg = JSON.parse(line);
      switch (msg.method) {
        case "initialize":
          send({ jsonrpc: "2.0", id: msg.id, result: { userAgent: "fake-codex/0.0.0" } });
          break;
        case "initialized":
          break;
        case "account/read":
          send({
            jsonrpc: "2.0",
            id: msg.id,
            result:
              state === "loggedin"
                ? {
                    account: {
                      type: "chatgpt",
                      email: "test@example.com",
                      planType: "plus",
                      // ブリッジが素通ししないことを検証するための「漏れてはいけない」ダミー値
                      accessToken: "sk-secret-DO-NOT-LEAK",
                    },
                    requiresOpenaiAuth: true,
                  }
                : { account: null, requiresOpenaiAuth: true },
          });
          break;
        case "account/login/start":
          send({
            jsonrpc: "2.0",
            id: msg.id,
            result: {
              type: "chatgpt",
              loginId: "login-1",
              authUrl: "https://auth.example.com/oauth",
            },
          });
          if (login !== "none") {
            setTimeout(() => {
              send({
                jsonrpc: "2.0",
                method: "account/login/completed",
                params: {
                  loginId: "login-1",
                  success: login === "success",
                  error: login === "fail" ? "login was cancelled by user" : null,
                },
              });
            }, 100);
          }
          break;
        case "account/logout":
          send({ jsonrpc: "2.0", id: msg.id, result: {} });
          break;
        case "thread/start":
          send({ jsonrpc: "2.0", id: msg.id, result: { thread: { id: `t${++threadCount}` } } });
          break;
        case "turn/start": {
          const threadId = msg.params.threadId;
          send({ jsonrpc: "2.0", id: msg.id, result: { turn: { id: `turn-${threadId}`, status: "inProgress" } } });
          const sleep = Number(process.env.FAKE_CODEX_TURN_SLEEP ?? "0");
          setTimeout(() => {
            send({ jsonrpc: "2.0", method: "item/agentMessage/delta", params: { threadId, turnId: `turn-${threadId}`, itemId: "i1", delta: "これは" } });
            send({ jsonrpc: "2.0", method: "item/agentMessage/delta", params: { threadId, turnId: `turn-${threadId}`, itemId: "i1", delta: "テスト応答です" } });
            send({ jsonrpc: "2.0", method: "item/completed", params: { threadId, turnId: `turn-${threadId}`, completedAtMs: 0, item: { id: "i1", type: "agentMessage", text: "これはテスト応答です" } } });
            send({ jsonrpc: "2.0", method: "turn/completed", params: { threadId, turn: { id: `turn-${threadId}`, status: "completed", items: [] } } });
          }, sleep);
          break;
        }
        case "turn/interrupt":
          send({ jsonrpc: "2.0", id: msg.id, result: {} });
          break;
        default:
          send({
            jsonrpc: "2.0",
            id: msg.id,
            error: { code: -32601, message: `unknown method ${msg.method}` },
          });
      }
    }
  });
} else {
  process.exit(2);
}
